---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/sections/Header.astro';
import Hero from '../components/sections/Hero.astro';
import RuleOfThumb from '../components/sections/RuleOfThumb.astro';
import CaseStudies from '../components/sections/CaseStudies.astro';
import Process from '../components/sections/Process.astro';
import Exclusions from '../components/sections/Exclusions.astro';
import Team from '../components/sections/Team.astro';
import FAQ from '../components/sections/FAQ.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
import CashCardForm from '../components/islands/quote/CashCardForm';
---

<BaseLayout title="DSCR Investors Network. How much cash can your rental pull?">
  <Header />
  <Hero />
  <section
    id="cash-card-form"
    class="bg-off-white py-16 md:py-24"
    aria-label="4-Question Cash Card form"
  >
    <CashCardForm client:load />
  </section>
  <RuleOfThumb />
  <CaseStudies />
  <Process />
  <Exclusions />
  <Team />
  <FAQ />
  <FinalCTA />
  <Footer />
</BaseLayout>

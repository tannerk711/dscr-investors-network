---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/sections/Header.astro';
import Hero from '../components/sections/Hero.astro';
import RecentClosedDeals from '../components/sections/RecentClosedDeals.astro';
import Process from '../components/sections/Process.astro';
import Exclusions from '../components/sections/Exclusions.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
import { StickyMobileCTA } from '../components/islands/nav/StickyMobileCTA';
import { ScrollProgress } from '../components/islands/nav/ScrollProgress';
import { hero } from '../content';
---

<BaseLayout title="DSCR Investors Network. How much cash can your rental pull?">
  <ScrollProgress client:load />
  <Header />
  <Hero />
  <RecentClosedDeals />
  <Process />
  <Exclusions />
  <FinalCTA />
  <Footer />
  <StickyMobileCTA client:load label={`${hero.ctaLabel} →`} />
</BaseLayout>

---
/**
 * Header — sticky top nav for the single-page LP.
 * White bg, brand wordmark left, single CTA right. No hamburger, no phone, no nav links.
 * Shadow is always on for v1 (position: sticky).
 */
import { hero } from '../../content';
---

<header
  class="sticky top-0 z-50 w-full border-b border-gray-100 bg-white shadow-md"
>
  <div
    class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8"
  >
    {/* Brand logo */}
    <a
      href="#top"
      class="flex items-center focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-navy"
      aria-label="DSCR Investors Network home"
    >
      <img
        src="/logo.png"
        alt="DSCR Investors Network"
        width="280"
        height="120"
        class="h-10 w-auto sm:h-12"
      />
    </a>

    {/* Single CTA (always visible; no mobile hamburger) */}
    <a
      href="#cash-card-form"
      class="inline-flex items-center gap-2 rounded-xl bg-red-accent px-4 py-2.5 text-sm font-bold text-white shadow-sm transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-navy sm:px-6 sm:py-3"
    >
      <span>{hero.ctaLabel}</span>
      <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</header>

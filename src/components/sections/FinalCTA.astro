---
import { finalCta } from '../../content';
---

<section class="bg-ink py-20 md:py-28 text-center">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-5xl font-bold text-white">
      {finalCta.headline}
    </h2>
    <a
      href="#cash-card-form"
      class="mt-8 inline-block bg-red-accent text-white font-bold px-10 py-5 rounded-xl hover:shadow-xl transition-shadow"
    >
      {finalCta.ctaLabel} &rarr;
    </a>
  </div>
</section>

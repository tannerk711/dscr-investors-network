---
import { caseStudies } from '../../content';

const isTodo = (v: string) => v === 'TODO_CLIENT';
const display = (v: string) => (isTodo(v) ? '[TODO_CLIENT]' : v);
const initial = (name: string) =>
  isTodo(name) ? '?' : name.charAt(0).toUpperCase();
---

<section class="bg-white py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">
      Recent Cash-Outs
    </p>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink">
      {caseStudies.headline}
    </h2>
    <p class="mt-4 text-lg text-gray-600">
      Anonymized to first names. Numbers are real.
    </p>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        caseStudies.studies.map((s) => (
          <div class="bg-white border border-gray-200 rounded-2xl shadow-md p-6 md:p-8 text-left">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 rounded-full bg-navy text-white flex items-center justify-center text-xl font-bold">
                {initial(s.firstName)}
              </div>
              <div>
                <p class="text-base font-semibold text-ink">
                  {display(s.firstName)}
                  {isTodo(s.city) || isTodo(s.state) ? (
                    <span>, [TODO_CLIENT]</span>
                  ) : (
                    <span>, {s.city} {s.state}</span>
                  )}
                </p>
                <span class="mt-1 inline-block bg-navy-light text-navy rounded-full px-3 py-1 text-xs font-semibold">
                  {display(s.propertyType)}
                </span>
              </div>
            </div>

            <div class="mt-6">
              <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">
                Cash at close
              </p>
              <p class="mt-1 text-3xl font-bold tabular-nums text-success">
                {display(s.cashOut)}
              </p>
            </div>

            <div class="mt-4">
              <p class="text-base text-gray-600 tabular-nums">
                {display(s.monthlyCashFlow)} cash flow
              </p>
            </div>

            <div class="mt-4">
              <span class="inline-block bg-off-white border border-gray-200 text-ink rounded-full px-3 py-1 text-xs font-semibold tabular-nums">
                {display(s.daysToClose)} days to close
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

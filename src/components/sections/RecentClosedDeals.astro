---
/**
 * RecentClosedDeals — horizontal auto-sliding gallery of recent closings.
 * Motion mirrors FundedTicker: pure-CSS marquee, list duplicated, pause on
 * hover/focus, frozen under prefers-reduced-motion.
 */
const deals = [
  {
    img: '/deals/miami-fl.png',
    location: 'Miami, FL',
    propertyValue: '$620K',
    fico: 742,
    cashOut: '$180K',
  },
  {
    img: '/deals/austin-tx.png',
    location: 'Austin, TX',
    propertyValue: '$710K',
    fico: 768,
    cashOut: '$240K',
  },
  {
    img: '/deals/seattle-wa.png',
    location: 'Seattle, WA',
    propertyValue: '$895K',
    fico: 721,
    cashOut: '$310K',
  },
  {
    img: '/deals/charleston-sc.png',
    location: 'Charleston, SC',
    propertyValue: '$485K',
    fico: 704,
    cashOut: '$135K',
  },
  {
    img: '/deals/austin-tx-2.png',
    location: 'Austin, TX',
    propertyValue: '$560K',
    fico: 729,
    cashOut: '$165K',
  },
  {
    img: '/deals/white-plains-ny.png',
    location: 'White Plains, NY',
    propertyValue: '$980K',
    fico: 755,
    cashOut: '$290K',
  },
];
---

<section class="bg-off-white py-16 md:py-24" aria-label="Recent closed deals">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10 text-center md:mb-14">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-success/30 bg-success/10 px-3 py-1">
        <span class="inline-block h-2 w-2 rounded-full bg-success"></span>
        <span class="text-xs font-semibold tracking-wide text-success">Recent Closings</span>
      </div>
      <h2 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">
        Recent Closed Deals
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-base leading-relaxed text-gray-600">
        Real results from our lead generation platform. These deals represent actual closings from leads we've delivered to our lending partners.
      </p>
    </div>
  </div>

  <div class="deals-marquee relative overflow-hidden">
    <div class="deals-track flex gap-6 py-2">
      {[...deals, ...deals].map((d) => (
        <article
          class="deal-card flex-shrink-0 w-[300px] sm:w-[340px] rounded-xl border border-gray-200 bg-white shadow-md overflow-hidden"
        >
          <div class="relative aspect-[4/3] w-full overflow-hidden bg-gray-100">
            <img
              src={d.img}
              alt={`Rental home in ${d.location}`}
              loading="lazy"
              class="h-full w-full object-cover"
            />
            <span class="absolute left-3 top-3 rounded-md bg-success px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest text-white shadow-md">
              Closed
            </span>
          </div>
          <div class="p-4">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-gray-500">
                  Location
                </p>
                <p class="mt-0.5 truncate text-sm font-semibold text-ink">
                  {d.location}
                </p>
              </div>
              <div class="text-right">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-gray-500">
                  Cash Out
                </p>
                <p class="mt-0.5 text-base font-extrabold tabular-nums text-success">
                  {d.cashOut}
                </p>
              </div>
            </div>
            <div class="mt-3 grid grid-cols-2 gap-3 border-t border-gray-200 pt-3">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-widest text-gray-500">
                  Property Value
                </p>
                <p class="mt-0.5 text-sm font-bold tabular-nums text-ink">
                  {d.propertyValue}
                </p>
              </div>
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-widest text-gray-500">
                  FICO
                </p>
                <p class="mt-0.5 text-sm font-bold tabular-nums text-ink">
                  {d.fico}
                </p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes deals-scroll {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-50%, 0, 0); }
  }

  .deals-track {
    width: max-content;
    animation: deals-scroll 60s linear infinite;
    will-change: transform;
  }

  .deals-marquee:hover .deals-track,
  .deals-marquee:focus-within .deals-track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .deals-track {
      animation: none;
    }
  }
</style>

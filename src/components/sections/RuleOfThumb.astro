---
import { ruleOfThumb } from '../../content';

const formatLoan = (n: number) => `$${(n / 1000).toFixed(0)}K loan`;
const formatRent = (n: number) =>
  `$${n.toLocaleString('en-US')}/mo rent`;

const resultTone = (result: string): 'positive' | 'negative' | 'neutral' => {
  if (result.includes('-$')) return 'negative';
  if (/breakeven/i.test(result)) return 'neutral';
  return 'positive';
};
---

<section class="bg-navy-light py-16 md:py-24">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">
      Rule of Thumb
    </p>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink">
      {ruleOfThumb.headline}
    </h2>
    <p class="mt-4 text-lg text-gray-600">
      {ruleOfThumb.subheadline}
    </p>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        ruleOfThumb.examples.map((ex) => {
          const tone = resultTone(ex.result);
          const toneClass =
            tone === 'positive'
              ? 'text-success'
              : tone === 'negative'
                ? 'text-red-accent'
                : 'text-navy';
          return (
            <div class="bg-white rounded-2xl shadow-md p-6 text-center">
              <p class="text-lg font-semibold text-ink tabular-nums">
                {formatLoan(ex.loan)}
              </p>
              <p class="mt-2 text-base text-gray-500 tabular-nums">
                {formatRent(ex.rent)}
              </p>
              <p class={`mt-4 text-base font-semibold tabular-nums ${toneClass}`}>
                {ex.result}
              </p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

---
/**
 * Hero — Section 1 of the DSCR Investors Network LP.
 * Split 50/50 on desktop, stacked on mobile. Ink background (dark section).
 * Left: eyebrow, H1, subhead, CTA. Right: CashCardMock with a faint form decoy behind it.
 * Trust strip (4 items) lives below the split.
 * NO rate, NO DSCR ratio, NO LTV, NO stock photo, NO phone.
 */
import { hero } from '../../content';
import CashCardMock from './CashCardMock.astro';
---

<section
  class="relative overflow-hidden bg-ink text-white pt-24 pb-16 md:pt-32 md:pb-24"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {/* Split: copy left, cash card right */}
    <div class="grid items-center gap-10 md:grid-cols-2 md:gap-12 lg:gap-16">
      {/* LEFT: copy + CTA */}
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-widest text-gray-300"
        >
          DSCR Cash-Out Refi
        </p>

        <h1
          class="mt-4 text-4xl font-extrabold leading-[1.05] tracking-tight text-white md:text-6xl"
        >
          {hero.headline}
        </h1>

        <p class="mt-6 text-lg leading-relaxed text-gray-300 md:text-xl">
          {hero.subheadline}
        </p>

        <div class="mt-10">
          <a
            href="#cash-card-form"
            class="inline-flex items-center gap-2 rounded-xl bg-red-accent px-8 py-4 text-base font-bold tracking-wide text-white shadow-lg transition-all duration-200 hover:shadow-xl hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          >
            <span>{hero.ctaLabel}</span>
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>

      {/* RIGHT: CashCardMock with faint form decoy behind */}
      <div class="relative mt-4 md:mt-0">
        {/* Faint form-question decoy behind the card */}
        <div
          class="pointer-events-none absolute inset-0 flex items-start justify-center pt-6 opacity-20 select-none"
          aria-hidden="true"
        >
          <div class="w-full max-w-md rounded-2xl border border-white/20 bg-white/5 p-8 text-left">
            <p class="text-xs font-semibold uppercase tracking-widest text-white">
              Question 1 of 4
            </p>
            <p class="mt-4 text-2xl font-bold text-white">
              What's it worth today?
            </p>
            <div class="mt-6 h-12 rounded-xl border border-white/30 bg-white/5"></div>
          </div>
        </div>

        {/* The actual mock card, lifted above the decoy */}
        <div class="relative">
          <CashCardMock />
        </div>
      </div>
    </div>

    {/* Trust strip — 3 items, stacked on mobile / 3-col desktop */}
    <ul
      class="mt-16 grid gap-4 border-t border-white/10 pt-10 sm:gap-6 grid-cols-1 md:mt-20 md:grid-cols-3"
    >
      {
        hero.trustStrip.map((line) => (
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="mt-0.5 h-5 w-5 flex-shrink-0 text-success"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span class="text-sm leading-snug text-gray-300">{line}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

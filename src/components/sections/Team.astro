---
import { loBios } from '../../content';

const getInitials = (name: string) =>
  name
    .split(' ')
    .map((p) => p.charAt(0).toUpperCase())
    .join('')
    .slice(0, 2);
---

<section class="bg-navy-light py-16 md:py-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">
      The People Behind Your File
    </p>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink">
      {loBios.headline}
    </h2>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        loBios.people.map((person) => {
          const hasPhoto =
            person.photoUrl && person.photoUrl !== 'TODO_CLIENT';
          return (
            <article class="bg-white rounded-2xl shadow-md p-8 text-left">
              <div class="flex items-center gap-5">
                {hasPhoto ? (
                  <img
                    src={person.photoUrl}
                    alt={person.name}
                    class="w-24 h-24 rounded-full object-cover"
                  />
                ) : (
                  <div class="w-24 h-24 rounded-full bg-navy text-white flex items-center justify-center text-2xl font-bold">
                    {getInitials(person.name)}
                  </div>
                )}
                <div>
                  <h3 class="text-xl font-bold text-ink">{person.name}</h3>
                  <p class="mt-1 text-sm font-semibold uppercase tracking-wider text-gray-500">
                    {person.role}
                  </p>
                </div>
              </div>

              <p class="mt-6 text-base text-gray-600">{person.bio}</p>

              <blockquote class="mt-5 border-l-4 border-navy pl-4 italic text-ink">
                "{person.quote}"
              </blockquote>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

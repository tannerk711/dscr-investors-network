---
/**
 * BreakevenTeeter — Section 3A, replaces the static RuleOfThumb.
 *
 * Wraps the BreakevenTeeter React island with the same headline/subhead
 * the old RuleOfThumb section used, pulled from the same content source
 * so there's no copy drift. The island owns all the interactivity; this
 * Astro file is just the section chrome (eyebrow, H2, subhead, bg).
 */
import { ruleOfThumb } from '../../content';
import { BreakevenTeeter as BreakevenTeeterIsland } from '../islands/teeter/BreakevenTeeter';
---

<section
  id="breakeven-teeter"
  class="bg-navy-light py-16 md:py-24"
  aria-label="Breakeven teeter interactive rule of thumb"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">
      Rule of Thumb
    </p>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink">
      {ruleOfThumb.headline}
    </h2>
    <p class="mt-4 text-lg text-gray-600">
      {ruleOfThumb.subheadline}
    </p>

    <div class="mt-12">
      <BreakevenTeeterIsland client:visible />
    </div>
  </div>
</section>

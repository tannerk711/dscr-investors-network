---
import { faq } from '../../content';
---

<section class="bg-white py-16 md:py-24">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">
        FAQ
      </p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink">
        {faq.headline}
      </h2>
    </div>

    <div class="mt-10">
      {
        faq.items.map((item) => (
          <details class="faq-item group border border-gray-200 rounded-xl p-5 mb-3 bg-white">
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none font-semibold text-ink">
              <span>{item.q}</span>
              <svg
                class="faq-chevron w-5 h-5 shrink-0 text-gray-500 transition-transform duration-200"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="5 8 10 13 15 8" />
              </svg>
            </summary>
            <p class="mt-3 text-base text-gray-600">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }
</style>

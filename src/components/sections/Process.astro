---
import { process } from '../../content';
---

<section class="bg-off-white py-16 md:py-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">
        What Happens Next
      </p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink">
        {process.headline}
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        {process.subheadline}
      </p>
    </div>

    <ol class="mt-12 grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-4 relative">
      {
        process.steps.map((step, idx) => (
          <li class="relative flex flex-col items-center text-center px-2">
            {idx < process.steps.length - 1 && (
              <span
                aria-hidden="true"
                class="hidden md:block absolute top-8 left-1/2 w-full h-px bg-gray-200"
              />
            )}
            <div class="relative z-10 w-16 h-16 rounded-full bg-navy text-white flex items-center justify-center text-2xl font-bold tabular-nums shadow-md">
              {step.n}
            </div>
            <h3 class="mt-5 text-lg font-semibold text-ink">
              {step.title}
            </h3>
            <p class="mt-2 text-base text-gray-600">
              {step.body}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

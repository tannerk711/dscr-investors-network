---
import { process } from '../../content';
---

<section class="bg-off-white py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 md:mb-14">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-navy/20 bg-navy/5 px-3 py-1">
        <span class="inline-block h-2 w-2 rounded-full bg-navy"></span>
        <span class="text-[11px] font-semibold uppercase tracking-widest text-navy">
          What Happens Next
        </span>
      </div>
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-ink">
        {process.headline}
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-base leading-relaxed text-gray-600">
        {process.subheadline}
      </p>
    </div>

    <ol class="grid grid-cols-1 md:grid-cols-4 gap-4">
      {
        process.steps.map((step) => (
          <li class="rounded-xl border border-gray-200 bg-white p-5 shadow-md">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-navy/5 text-sm font-bold tabular-nums text-navy">
              {step.n}
            </div>
            <h3 class="mt-4 text-base font-semibold tracking-tight text-ink">
              {step.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-600">
              {step.body}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

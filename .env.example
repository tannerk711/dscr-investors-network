# DSCR Investors Network — environment variables
# Copy this file to `.env` (or set the same keys in Vercel project settings)
# and fill in real values. .env is git-ignored.

# Zapier webhook (lead intake → Salesforce routing)
ZAPIER_WEBHOOK_URL=

# Meta Pixel (client-side, fires PageView + custom events from the browser)
# Prefixed with PUBLIC_ so Vite/Astro inlines it into the browser bundle.
PUBLIC_META_PIXEL_ID=TODO_CLIENT

# Meta Conversions API (server-side Lead event for iOS 14.5+ attribution)
META_PIXEL_ID=TODO_CLIENT
META_CAPI_ACCESS_TOKEN=TODO_CLIENT
# Optional: set this to Meta's TEST#### code while testing in Events Manager
META_TEST_EVENT_CODE=

# Google Places API (address autocomplete in the contact step)
# Public because it's used from the browser. Restrict by HTTP referrer in GCP console.
PUBLIC_GOOGLE_PLACES_API_KEY=TODO_CLIENT
